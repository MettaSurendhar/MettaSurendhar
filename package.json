name: Profile Metrics
on:
  schedule:
    - cron: "0 0 * * *"   # daily at midnight UTC
  workflow_dispatch:
  push:
    branches: ["main", "master"]

jobs:

  # ------------------------------------------------------------------
  # lowlighter/metrics: main card, isometric (rolling) calendar, languages,
  # achievements, habits, notable contributions.
  # Kept as sequential steps in ONE job so each output_action:commit push
  # happens one at a time (parallel jobs pushing to the same branch would
  # conflict). retries + smaller scopes reduce the odds of the flaky
  # scraper-based plugins (achievements/habits) timing out.
  # ------------------------------------------------------------------
  github-metrics:
    runs-on: ubuntu-latest
    permissions:
      contents: write
    steps:

      - name: Main metrics card
        uses: lowlighter/metrics@latest
        with:
          filename: metrics.svg
          token: ${{ secrets.METRICS_TOKEN }}
          base: header, activity, community, repositories, metadata
          config_timezone: Asia/Kolkata
          retries: 3
          retries_delay: 3000

      - name: Isometric calendar (rolling 12 months)
        uses: lowlighter/metrics@latest
        with:
          filename: metrics.isocalendar.svg
          token: ${{ secrets.METRICS_TOKEN }}
          base: ""
          plugin_isocalendar: yes
          plugin_isocalendar_duration: full-year
          config_timezone: Asia/Kolkata
          retries: 3
          retries_delay: 3000

      - name: Languages
        uses: lowlighter/metrics@latest
        with:
          filename: metrics.languages.svg
          token: ${{ secrets.METRICS_TOKEN }}
          base: ""
          plugin_languages: yes
          plugin_languages_analysis_timeout: 20
          plugin_languages_details: bytes-size, percentage
          plugin_languages_threshold: 0%
          plugin_languages_limit: 8
          retries: 3
          retries_delay: 3000

      # Hardened: secrets scraping disabled (it's the heaviest, most
      # scraper-dependent part), curated "only" list keeps it from touching
      # the broken percentile-rank lookup entirely, compact display is lighter.
      - name: Achievements
        uses: lowlighter/metrics@latest
        continue-on-error: true
        with:
          filename: metrics.achievements.svg
          token: ${{ secrets.METRICS_TOKEN }}
          base: ""
          plugin_achievements: yes
          plugin_achievements_secrets: no
          plugin_achievements_display: compact
          plugin_achievements_only: >-
            polyglot, stargazer, sponsor, deployer, member,
            maintainer, developer, scripter, packager, explorer
          retries: 3
          retries_delay: 5000

      - name: Notable contributions
        uses: lowlighter/metrics@latest
        continue-on-error: true
        with:
          filename: metrics.notable.svg
          token: ${{ secrets.METRICS_TOKEN }}
          base: ""
          plugin_notable: yes
          plugin_notable_from: 200
          plugin_notable_types: commit, pr
          retries: 3
          retries_delay: 3000

      # Lighter config than before: charts dropped, fewer days scanned.
      # If this keeps failing, it's the GitHub-side rate limit noted above -
      # re-running the workflow (Actions tab -> Re-run jobs) usually clears it.
      - name: Coding habits
        uses: lowlighter/metrics@latest
        continue-on-error: true
        with:
          filename: metrics.habits.svg
          token: ${{ secrets.METRICS_TOKEN }}
          base: ""
          plugin_habits: yes
          plugin_habits_from: 100
          plugin_habits_days: 14
          plugin_habits_facts: yes
          plugin_habits_charts: no
          config_timezone: Asia/Kolkata
          retries: 3
          retries_delay: 5000

  # ------------------------------------------------------------------
  # Year-switchable contribution calendars. lowlighter/metrics' isocalendar
  # only supports a rolling half-year/full-year window, not fixed calendar
  # years, so this hits the GraphQL contributionsCollection(from, to) API
  # directly and renders one flat heatmap SVG per year in calendars/YYYY.svg.
  # README displays each year inside a <details> block to switch between them.
  # ------------------------------------------------------------------
  contribution-calendars:
    runs-on: ubuntu-latest
    needs: github-metrics
    permissions:
      contents: write
    steps:
      - uses: actions/checkout@v4
        with:
          ref: ${{ github.ref_name }}

      - uses: actions/setup-node@v4
        with:
          node-version: "20"

      - name: Install dependencies
        run: npm install

      - name: Render yearly calendars
        run: npm run calendars
        env:
          GITHUB_TOKEN: ${{ secrets.METRICS_TOKEN }}
          GH_USERNAME: MettaSurendhar
          YEARS: "2022,2023,2024,2025,2026"

      - name: Commit calendars
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"
          git add calendars
          git diff --staged --quiet || git commit -m "chore: update yearly contribution calendars [skip ci]"
          git push